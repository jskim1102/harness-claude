# ── Per-machine / generated (regenerated by run.sh on each clone) ───────────
# CEO/CTO working dirs are runtime workspaces: cmd_ceo mkdir's ceo/, add-cto
# spawns <name>/, and write_role_settings() bakes the local $REPO path into
# each .claude/ tree. All regenerated on demand — never committed.
claude-project/*
!claude-project/.gitkeep
# Local permission overrides (machine-specific allow-lists, absolute paths).
.claude/settings.local.json
**/settings.local.json
# Runtime locks + editor swap files.
**/scheduled_tasks.lock
*.swp
*.swo

# ── Vendored external source repos (pulled in by fetch-source / stock) ──────
# Large, machine-specific, not part of the harness itself.
.sources/
# Vendored external reference repos (aws-sample, oh-my-claudecode) — large, not part of the harness.
references/

# ── Module library (curated by the librarian at runtime) ───────────────────
# Vendored reusable feature modules — contents local, folder kept via .gitkeep.
modules/*
!modules/.gitkeep

# ── Generated output ───────────────────────────────────────────────────────
# Extraction plans written by /feature-extract.
feature-extract/

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.pytest_cache/

# ── Editor ─────────────────────────────────────────────────────────────────
.vscode/
